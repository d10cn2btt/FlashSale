// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────
// Users & Auth
// ─────────────────────────────────────────

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String    @map("password_hash")
  role         Role      @default(CUSTOMER)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  orders        Order[]
  refreshTokens RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  token     String    @unique
  family    String    // UUID — một session = một family
  revokedAt DateTime? @map("revoked_at")
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([family])
  @@map("refresh_tokens")
}

enum Role {
  CUSTOMER
  ADMIN
}

// ─────────────────────────────────────────
// Products & Inventory
// ─────────────────────────────────────────

model Product {
  id          String    @id @default(uuid())
  name        String
  description String?
  price       Decimal   @db.Decimal(12, 2)
  imageUrl    String?   @map("image_url")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  inventory  Inventory?
  flashSales FlashSale[]

  @@map("products")
}

model Inventory {
  id        String   @id @default(uuid())
  productId String   @unique @map("product_id")
  quantity  Int      @default(0)
  updatedAt DateTime @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id])

  @@map("inventory")
}

// ─────────────────────────────────────────
// Flash Sales
// ─────────────────────────────────────────

model FlashSale {
  id             String          @id @default(uuid())
  productId      String          @map("product_id")
  discountPrice  Decimal         @map("discount_price") @db.Decimal(12, 2)
  maxQty         Int             @map("max_qty")          // tổng số lượng cho phép mua
  soldQty        Int             @default(0) @map("sold_qty")
  startAt        DateTime        @map("start_at")
  endAt          DateTime        @map("end_at")
  status         FlashSaleStatus @default(UPCOMING)
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  deletedAt      DateTime?       @map("deleted_at")

  product Product @relation(fields: [productId], references: [id])
  orders  Order[]

  @@map("flash_sales")
}

enum FlashSaleStatus {
  UPCOMING
  ACTIVE
  ENDED
  CANCELLED
}

// ─────────────────────────────────────────
// Orders
// ─────────────────────────────────────────

model Order {
  id          String      @id @default(uuid())
  userId      String      @map("user_id")
  flashSaleId String      @map("flash_sale_id")
  qty         Int         @default(1)
  totalPrice  Decimal     @map("total_price") @db.Decimal(12, 2)
  status      OrderStatus @default(PENDING)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  deletedAt   DateTime?   @map("deleted_at")

  user      User      @relation(fields: [userId], references: [id])
  flashSale FlashSale @relation(fields: [flashSaleId], references: [id])

  @@index([userId])
  @@index([flashSaleId])
  @@map("orders")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  CANCELLED
  REFUNDED
}
